# Copy to load-test/.env and fill in staging values.
# k6 does not read .env automatically — use:  source load-test/run.sh smoke
# or pass -e flags manually.

# Staging backend (must include /api)
API_URL=https://cricket-auction-backend-staging.onrender.com/api

# Staging frontend (for your reference when opening /view links manually)
FRONTEND_URL=https://cricket-auction-staging.netlify.app

# Tournament to test (create one in staging admin UI first)
TOURNAMENT_ID=1

# Optional overlay secret token (leave empty for public /view links)
OVERLAY_TOKEN=

# Admin credentials for auction-bids.js (staging only — never production secrets in git)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# First team ID in the tournament (check Teams page)
TEAM_ID=1

# overlay-viewers.js tuning
VUS_MAX=100
VIEWER_DURATION_SEC=600
# STAGES=1m:50,3m:100,5m:100,2m:0

# overlay-poll-only.js — keep low (20-50)
# VUS_MAX=30
# POLL_INTERVAL_SEC=3

# auction-bids.js
BID_INTERVAL_SEC=4
DURATION=15m
