PORT=5055

# Set this and use the same value in backend CRICHEROES_WORKER_TOKEN.
CRICHEROES_WORKER_TOKEN=change-me

# Persistent browser profile directory. Back this up; it contains the paid-login session.
CRICHEROES_USER_DATA_DIR=.auth/cricheroes-profile

# Server mode should normally be headless. The login command always opens a visible browser.
CRICHEROES_HEADLESS=true

# Optional timeout for page loads.
CRICHEROES_FETCH_TIMEOUT_MS=25000
